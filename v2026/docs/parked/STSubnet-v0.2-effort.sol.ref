// SPDX-License-Identifier: MIT
pragma solidity 0.8.24;

import {Initializable} from "@openzeppelin/contracts-upgradeable/proxy/utils/Initializable.sol";
import {UUPSUpgradeable} from "@openzeppelin/contracts-upgradeable/proxy/utils/UUPSUpgradeable.sol";
import {OwnableUpgradeable} from "@openzeppelin/contracts-upgradeable/access/OwnableUpgradeable.sol";
import {MerkleProof} from "@openzeppelin/contracts/utils/cryptography/MerkleProof.sol";

import {IStaking, ISTAKING_ADDRESS} from "./interfaces/stakingV2.sol";
import {INeuron, INeuron_ADDRESS} from "./interfaces/neuron.sol";
import {IMetagraph, IMetagraph_ADDRESS} from "./interfaces/metagraph.sol";
import {IEd25519Verify, IED25519VERIFY_ADDRESS} from "./interfaces/ed25519Verify.sol";
import {Blake2b} from "./lib/Blake2b.sol";

/// @title STSubnet — custody / settlement core for the UR Bittensor subnet.
///
/// @notice One UUPS-upgradeable contract that is simultaneously (WHITEPAPER §6):
///         the subnet's α custodian (a coldkey via the EVM mirror), the deposit
///         ledger, the miner-pool emission custodian (it `burnedRegister`s and
///         owns every NO's pool UID), the validator effort-bounty payer, and the
///         per-epoch settlement / pull-claims engine. It is NOT the subnet
///         validator: independent validators set weights themselves and earn
///         native dividends; this contract custodies only the miner emission
///         and the fee pool.
///
/// @dev STRUCTURAL INVARIANT (WHITEPAPER §6.4, D-12): once `finalizeEpoch(e)`
///      runs, the claims of epoch `e` are sacrosanct. No owner, guardian,
///      pause, parameter, or upgrade path in this contract writes to
///      `poolTotal[e]`, `feePool[e]` (post-finalize), `effort[e]`,
///      `totalEffort[e]`, `noCommit[e]`, or the claim dedup/cap state of a
///      finalized epoch, and the claim functions carry no pause gate.
///      Admin power reaches only future epochs.
///
///      Every subtensor precompile is reached through a small virtual accessor
///      (see "precompile accessors") because the precompile ABIs are UNVERIFIED
///      against the live runtime (PLAN.md SP-1). Tests mock them with vm.etch.
contract STSubnet is Initializable, UUPSUpgradeable, OwnableUpgradeable {
    // ---------------------------------------------------------------------
    // Types
    // ---------------------------------------------------------------------

    /// @dev WHITEPAPER §6.1. Field order is pinned by stctl/st_abi.json.
    struct Operator {
        bytes32 coldkey; // NO's substrate coldkey (informational / governance)
        uint16 minerUid; // pool UID owned by this contract (accrual slot)
        bytes32 minerHotkey; // pool hotkey emission accrues on (D-4)
        bool active;
    }

    /// @dev WHITEPAPER §6.1. Field order is pinned by stctl/st_abi.json.
    struct Validator {
        bytes32 hotkey; // sr25519 hotkey of the validator's own UID
        bytes32 vpk; // Ed25519 trail-verification public key
        address operator; // EVM wallet that registered / operates this validator
        bool active;
    }

    /// @dev WHITEPAPER §6.1.
    struct NoCommit {
        bytes32 payoutRoot; // Merkle root over (provider coldkey, shareBps) leaves
        bytes off; // off-chain pointer (IPFS/HTTPS) to the full payout list
    }

    /// @dev Globally-unique server trail-signing key (append-only registry).
    ///      A trail leaf names only `serverKeyId`; this struct binds it to a NO.
    struct ServerKey {
        uint256 noId;
        bytes32 pubkey; // Ed25519 public key signing FINAL trail digests
    }

    /// @dev One effort claim per (epoch, valId) — optimistic, then sampled,
    ///      then disputable (WHITEPAPER §9.3, §11.3).
    struct TrailSubmission {
        uint256 claimedEffort; // Σ coverage claimed by the validator
        uint64 submitBlock;
        uint64 seedBlock; // blockhash(seedBlock) seeds the sample indices
        uint256 leafCount; // declared at proveTrailSamples
        bool proven; // sampled verification passed (or sampleK == 0)
        bool voided; // a dispute succeeded — effort is 0 forever
    }

    /// @dev The full preimage of one effort-tree leaf. The leaf commits to the
    ///      SIGNATURES (not just (pathId, coverage)) so that disputes are
    ///      cryptographically decidable from the root alone — see README
    ///      "Effort leaf" deviation note.
    struct TrailLeaf {
        uint256 index; // 0-based position; binds random sampling
        bytes32 pathId; // trail / path identifier
        uint256 coverage; // coverage-weighted effort of this trail
        uint64 serverKeyId; // -> serverKeys registry
        bytes32 finalDigest; // 32-byte digest of the trail FINAL message
        bytes32 serverSigR; // Ed25519 sig by serverKeys[serverKeyId].pubkey
        bytes32 serverSigS; //   over finalDigest
        bytes32 vpkSigR; // Ed25519 sig by the validator's vpk
        bytes32 vpkSigS; //   over finalDigest
    }

    // ---------------------------------------------------------------------
    // Constants
    // ---------------------------------------------------------------------

    uint256 public constant BPS = 10_000;
    /// @dev Cap on lazy epoch rolls per call so a long-idle contract can be
    ///      caught up in chunks via rollEpochs() without exceeding block gas.
    uint256 public constant MAX_ROLLS_PER_CALL = 32;
    // Bounds the operator set so the per-roll sweep and the finalize/roll loops
    // cannot be pushed past the block gas limit (matches the max_uids cap).
    // internal: no external consumer, and keeps the ABI stable.
    uint256 internal constant MAX_OPERATORS = 256;
    // HF-2: max reseeds of the sample seed per (e,valId). Preserves the
    // legitimate late-prove reseed (blockhash falls out of the 256-block window)
    // while capping the resample-grind to a small number of draws.
    uint16 internal constant MAX_RESEEDS = 2;
    /// @dev Domain separator of the registerValidator vpk-binding digest.
    bytes32 public constant VPK_BIND_DOMAIN = keccak256("UR_ST_VPK_BIND_V1");
    /// @dev Domain separator of the head-tier client_id<->hotkey bind digest.
    bytes32 public constant HEAD_BIND_DOMAIN = keccak256("UR_ST_HEAD_BIND_V1");

    // ---------------------------------------------------------------------
    // Storage (append-only across upgrades)
    // ---------------------------------------------------------------------

    // --- core config ---
    uint16 public netuid;
    bytes32 public treasuryHotkey; // custody hotkey for deposits + fee pool + swept emission
    bytes32 public selfColdkey; // mirror(address(this)) — the contract's substrate coldkey
    address public guardian; // pause-only role (D-12)
    bool public paused;

    // --- epoch machine (D-11: all governance-settable, in blocks) ---
    uint256 public epoch; // current OPEN epoch index
    uint64 public epochStartBlock; // start block of the current open epoch
    uint64 public tEpoch; // epoch length (50_400 mainnet default)
    uint64 public commitWindowBlocks; // +4h default (1_200 @ 12s)
    uint64 public trailsWindowBlocks; // +24h default (7_200)
    uint64 public finalizeOffsetBlocks; // +48h default (14_400)
    uint16 public sampleK; // sampled effort-leaf verification count
    mapping(uint256 => uint64) public epochCloseBlock; // e -> intended close block (set at roll)

    // F2 fix: the commit/trails/dispute/finalize window lengths are frozen
    // per-epoch AT CLOSE. Every deadline guard reads this snapshot, never the
    // live setters, so `setEpochParams` can only change epochs that close AFTER
    // the call — a pending epoch's deadlines can never be moved out from under
    // an in-flight commit, prove, or dispute (upholds D-12 "future epochs only").
    struct EpochWindowSnapshot {
        uint64 commitWindowBlocks;
        uint64 trailsWindowBlocks;
        uint64 finalizeOffsetBlocks;
    }
    mapping(uint256 => EpochWindowSnapshot) internal epochWindows; // e -> window params at close

    // --- fee params ---
    uint256 public phiBps; // non-refundable deposit fraction φ -> fee pool
    uint256 public omegaBps; // advisory ω slice of the owner cut (routed via fundFeePool)

    // --- registries ---
    mapping(uint256 => Operator) public operators; // noId -> Operator
    uint256[] public operatorIds;
    mapping(uint256 => address) public operatorAddress; // noId -> authorized deposit/commit wallet
    mapping(bytes32 => bool) public minerHotkeyUsed;
    mapping(uint64 => ServerKey) public serverKeys; // serverKeyId -> key (append-only)

    mapping(uint256 => Validator) public validators; // valId -> Validator
    uint256 public nextValId; // valIds start at 1; 0 = none
    mapping(bytes32 => uint256) public vpkToValidator;
    mapping(bytes32 => uint256) public hotkeyToValidator;
    mapping(uint256 => bytes32) public validatorColdkey; // valId -> substrate coldkey paid by claimValidator
    bool public mirrorCheckEnabled; // false => permissionless registerValidator disabled (SP-1 fallback)

    // --- per-epoch deposit ledger (α, rao) ---
    mapping(uint256 => mapping(uint256 => uint256)) public DT; // e -> noId -> gross deposits
    mapping(uint256 => uint256) public totalDT; // e -> Σ_n gross deposits
    mapping(uint256 => mapping(uint256 => uint256)) public depositNet; // e -> noId -> (1-φ) portion
    mapping(uint256 => uint256) public feePool; // e -> φ·deposits + fundFeePool amounts
    /// @dev α on treasuryHotkey already attributed by this ledger. Deposits are
    ///      push-then-credit (see README: StakingV2 v3.2.7 has no
    ///      transferStakeFrom): getStake(treasury) - accountedStake = pushed,
    ///      not-yet-credited α available to deposit()/fundFeePool().
    uint256 public accountedStake;

    // --- pool emission measurement (D-4: stake-delta snapshots) ---
    mapping(uint256 => uint256) public poolBaseline; // noId -> unswept stake already measured
    mapping(uint256 => uint256) public poolAccrued; // noId -> emission attributed to the open epoch
    mapping(uint256 => mapping(uint256 => uint256)) public poolEmission; // e -> noId -> measured emission
    mapping(uint256 => uint256) public carry; // noId -> pool total carried from missed commits

    // --- per-epoch operator commitment ---
    mapping(uint256 => mapping(uint256 => NoCommit)) public noCommit; // e -> noId

    // --- per-epoch validator effort ---
    mapping(uint256 => mapping(uint256 => bytes32)) public trailsRoot; // e -> valId
    mapping(uint256 => mapping(uint256 => uint256)) public effort; // e -> valId (CREDITED, post sample+dispute)
    mapping(uint256 => mapping(uint256 => TrailSubmission)) public trailSubmission; // e -> valId
    mapping(uint256 => uint256) public totalEffort; // e -> Σ credited effort
    // HF-2: bound reseeds per (e,valId) so reseedTrailSamples cannot be used as
    // a keep-the-best resample oracle to grind the effort estimator. internal
    // (no getter) to keep the ABI stable.
    mapping(uint256 => mapping(uint256 => uint16)) internal reseedCount;

    // --- per-epoch settlement (append-only once finalized) ---
    mapping(uint256 => mapping(uint256 => uint256)) public poolTotal; // e -> noId
    mapping(uint256 => mapping(uint256 => uint256)) public claimedMiner; // e -> noId -> α paid out
    mapping(uint256 => bool) public finalized;
    uint256 public nextFinalizeEpoch;
    mapping(uint256 => mapping(bytes32 => bool)) public minerClaimedBy; // e -> keccak(noId,coldkey)
    mapping(uint256 => mapping(uint256 => bool)) public valClaimed; // e -> valId

    // ---------------------------------------------------------------------
    // Events (the off-chain sync in st_controller is built on these — SP-4)
    // ---------------------------------------------------------------------

    event OperatorRegistered(
        uint256 indexed noId, bytes32 coldkey, uint16 minerUid, bytes32 minerHotkey
    );
    event OperatorAddressSet(uint256 indexed noId, address addr);
    event OperatorActiveSet(uint256 indexed noId, bool active);
    event OperatorServerKeySet(uint256 indexed noId, uint64 indexed serverKeyId, bytes32 pubkey);
    event ValidatorRegistered(
        uint256 indexed valId, bytes32 hotkey, bytes32 vpk, address operator, bytes32 coldkey
    );
    event ValidatorActiveSet(uint256 indexed valId, bool active);

    // Head tier (WHITEPAPER §8.4/§11.4): the two lookup keys (hotkey, clientId)
    // are indexed so validators can filter the binding log cheaply.
    event HeadBound(
        bytes32 indexed hotkey, bytes32 indexed clientId, uint16 uid, address registrant
    );
    event HeadUnbound(
        bytes32 indexed hotkey, bytes32 indexed clientId, uint16 uid, address registrant
    );

    event Deposited(
        uint256 indexed e, uint256 indexed noId, address from, uint256 amount, uint256 fee
    );
    event FeePoolFunded(uint256 indexed e, address from, uint256 amount);

    event EpochRolled(uint256 indexed closedEpoch, uint256 indexed newEpoch, uint64 closeBlock);
    event PoolSwept(uint256 indexed noId, uint256 measured, uint256 swept, bool moveOk);

    event OperatorCommitted(uint256 indexed e, uint256 indexed noId, bytes32 payoutRoot, bytes off);
    event TrailsSubmitted(
        uint256 indexed e, uint256 indexed valId, bytes32 trailsRoot, uint256 claimedEffort
    );
    event TrailSamplesReseeded(uint256 indexed e, uint256 indexed valId, uint64 seedBlock);
    event TrailSamplesProven(uint256 indexed e, uint256 indexed valId, uint256 leafCount);
    event TrailLeafDisputed(
        uint256 indexed e, uint256 indexed valId, address indexed disputer, bytes32 leafHash
    );

    event EpochFinalized(
        uint256 indexed e, uint256 totalDT, uint256 feePool, uint256 totalEffort
    );
    event PoolFinalized(uint256 indexed e, uint256 indexed noId, uint256 poolTotal);
    event PoolCarried(uint256 indexed e, uint256 indexed noId, uint256 carried);
    event FeePoolRolled(uint256 indexed fromEpoch, uint256 indexed toEpoch, uint256 amount);

    event MinerClaimed(
        uint256 indexed e,
        uint256 indexed noId,
        bytes32 indexed coldkey,
        uint256 shareBps,
        uint256 amount,
        address caller
    );
    event ValidatorClaimed(uint256 indexed e, uint256 indexed valId, uint256 amount, address caller);

    event FeeParamsSet(uint256 phiBps, uint256 omegaBps);
    event EpochParamsSet(
        uint64 tEpoch, uint64 commitWindowBlocks, uint64 trailsWindowBlocks, uint64 finalizeOffsetBlocks
    );
    event SampleKSet(uint16 sampleK);
    event GuardianSet(address guardian);
    event PausedSet(bool paused, address by);
    event MirrorCheckSet(bool enabled);
    event SelfColdkeySet(bytes32 selfColdkey);

    /// @dev Minimal storage-based reentrancy flag. Deliberately NOT OZ's
    ///      ReentrancyGuardTransient: transient storage (EIP-1153) support on
    ///      the subtensor Frontier EVM is unverified (SP-1), and the
    ///      upgradeable package no longer ships a storage-based guard.
    uint256 private _reentrancy;

    // ---------------------------------------------------------------------
    // Modifiers
    // ---------------------------------------------------------------------

    modifier nonReentrant() {
        require(_reentrancy == 0, "ST: reentrancy");
        _reentrancy = 1;
        _;
        _reentrancy = 0;
    }

    /// @dev Guardian pause surface (D-12): deposits, effort submission and
    ///      NEW claim opening (finalize). Never on claim/dispute paths.
    modifier whenNotPausedST() {
        require(!paused, "ST: paused");
        _;
    }

    modifier onlyOperatorOrOwner(uint256 noId) {
        require(
            msg.sender == owner() || msg.sender == operatorAddress[noId],
            "ST: not operator"
        );
        _;
    }

    // ---------------------------------------------------------------------
    // Initialization
    // ---------------------------------------------------------------------

    /// @custom:oz-upgrades-unsafe-allow constructor
    constructor() {
        _disableInitializers();
    }

    /// @notice Initializer (replaces the st_abi.json v1 constructor — UUPS).
    /// @param selfColdkey_ bytes32(0) => compute mirror(address(this)) on-chain
    ///        via blake2f (0x09); pass an explicit value if 0x09 is unavailable
    ///        on the target runtime (SP-1 fallback).
    function initialize(
        uint16 netuid_,
        address owner_,
        address guardian_,
        bytes32 treasuryHotkey_,
        uint64 tEpoch_,
        uint64 commitWindowBlocks_,
        uint64 trailsWindowBlocks_,
        uint64 finalizeOffsetBlocks_,
        uint256 phiBps_,
        uint256 omegaBps_,
        uint16 sampleK_,
        bytes32 selfColdkey_
    ) external initializer {
        __Ownable_init(owner_);

        require(treasuryHotkey_ != bytes32(0), "ST: treasury hotkey 0");
        _checkEpochParams(tEpoch_, commitWindowBlocks_, trailsWindowBlocks_, finalizeOffsetBlocks_);
        require(phiBps_ <= BPS && omegaBps_ <= BPS, "ST: bps > 10000");

        netuid = netuid_;
        guardian = guardian_;
        treasuryHotkey = treasuryHotkey_;
        tEpoch = tEpoch_;
        commitWindowBlocks = commitWindowBlocks_;
        trailsWindowBlocks = trailsWindowBlocks_;
        finalizeOffsetBlocks = finalizeOffsetBlocks_;
        phiBps = phiBps_;
        omegaBps = omegaBps_;
        sampleK = sampleK_;
        selfColdkey = selfColdkey_ == bytes32(0) ? _mirror(address(this)) : selfColdkey_;
        mirrorCheckEnabled = true;

        epoch = 0;
        epochStartBlock = uint64(block.number);
        nextValId = 1;

        emit SelfColdkeySet(selfColdkey);
        emit EpochParamsSet(tEpoch_, commitWindowBlocks_, trailsWindowBlocks_, finalizeOffsetBlocks_);
        emit FeeParamsSet(phiBps_, omegaBps_);
        emit SampleKSet(sampleK_);
        emit GuardianSet(guardian_);
    }

    /// @dev The contract must be able to hold native TAO (gas / burnedRegister
    ///      burns are deducted from its mirror account).
    receive() external payable {}

    // ---------------------------------------------------------------------
    // Epoch machine
    // ---------------------------------------------------------------------

    /// @notice Lazily roll the epoch counter over every elapsed boundary
    ///         (bounded by MAX_ROLLS_PER_CALL). Permissionless. At each roll
    ///         the per-pool emission delta is measured (D-4) and swept onto
    ///         treasuryHotkey.
    function rollEpochs() external nonReentrant {
        _rollEpochs();
    }

    /// @notice Epoch index the chain is currently in (view; ignores unrolled state).
    function pendingEpoch() public view returns (uint256) {
        return epoch + (block.number - uint256(epochStartBlock)) / uint256(tEpoch);
    }

    function _rollEpochs() internal {
        uint256 rolls = 0;
        while (
            block.number >= uint256(epochStartBlock) + uint256(tEpoch) && rolls < MAX_ROLLS_PER_CALL
        ) {
            uint256 e = epoch;
            uint64 closeB = epochStartBlock + tEpoch; // intended boundary, not roll block
            epochCloseBlock[e] = closeB;
            // freeze this epoch's window lengths (F2): later setEpochParams
            // calls cannot retroactively move e's deadlines
            epochWindows[e] = EpochWindowSnapshot({
                commitWindowBlocks: commitWindowBlocks,
                trailsWindowBlocks: trailsWindowBlocks,
                finalizeOffsetBlocks: finalizeOffsetBlocks
            });

            // D-4: measure per-pool emission as the stake delta on the pool's
            // own hotkey, then sweep it to the treasury hotkey. If the roll is
            // late, everything accrued since the last roll lands in epoch e.
            uint256 n = operatorIds.length;
            for (uint256 i = 0; i < n; i++) {
                uint256 noId = operatorIds[i];
                _sweepPool(noId);
                poolEmission[e][noId] = poolAccrued[noId];
                poolAccrued[noId] = 0;
            }

            epoch = e + 1;
            epochStartBlock = closeB;
            rolls++;
            emit EpochRolled(e, e + 1, closeB);
        }
    }

    /// @dev Reverts if lazy rolling could not fully catch up (extreme backlog);
    ///      call rollEpochs() repeatedly first.
    function _requireRolled() internal view {
        require(block.number < uint256(epochStartBlock) + uint256(tEpoch), "ST: roll backlog");
    }

    /// @notice Measure + sweep one pool's emission now (also runs at each roll).
    ///         Permissionless; useful to consolidate custody mid-epoch.
    function sweepPool(uint256 noId) external nonReentrant {
        require(operators[noId].minerHotkey != bytes32(0), "ST: no operator");
        _sweepPool(noId);
    }

    function _sweepPool(uint256 noId) internal {
        Operator storage op = operators[noId];
        if (op.minerHotkey == bytes32(0)) return;

        uint256 cur = _getStake(op.minerHotkey);
        uint256 base = poolBaseline[noId];
        uint256 delta = cur > base ? cur - base : 0;
        poolAccrued[noId] += delta;

        bool moveOk = true;
        if (cur > 0) {
            moveOk = _tryMoveStake(op.minerHotkey, treasuryHotkey, cur);
            if (moveOk) {
                poolBaseline[noId] = 0;
                accountedStake += cur; // swept α is custody, not an unattributed push
            } else {
                // measured but unswept: remember the level so it is not
                // double-counted at the next measurement.
                poolBaseline[noId] = cur;
            }
        } else {
            poolBaseline[noId] = 0;
        }
        emit PoolSwept(noId, delta, moveOk ? cur : 0, moveOk);
    }

    // ---------------------------------------------------------------------
    // Registries
    // ---------------------------------------------------------------------

    /// @notice Register a network operator (owner-gated, WHITEPAPER §6.2).
    ///         The contract `burnedRegister`s `minerHotkey` on the subnet via
    ///         the Neuron precompile — the pool UID is owned by this contract
    ///         (coldkey = mirror(this)) and is a pure accrual slot.
    /// @dev The contract's account must hold enough TAO for the registration
    ///      burn (fund via plain transfer; burn denomination is SP-1-gated).
    function registerOperator(uint256 noId, bytes32 coldkey, bytes32 minerHotkey)
        external
        onlyOwner
        nonReentrant
    {
        require(operatorIds.length < MAX_OPERATORS, "ST: max operators");
        require(operators[noId].minerHotkey == bytes32(0), "ST: noId exists");
        require(minerHotkey != bytes32(0), "ST: hotkey 0");
        // a pool hotkey equal to the treasury hotkey would make the stake-delta
        // emission sweep book the whole treasury as this pool's emission and
        // double-count accountedStake — reject it (review finding C)
        require(minerHotkey != treasuryHotkey, "ST: hotkey==treasury");
        require(!minerHotkeyUsed[minerHotkey], "ST: hotkey used");
        minerHotkeyUsed[minerHotkey] = true;

        _burnedRegister(netuid, minerHotkey);
        uint16 uid = _findUid(minerHotkey);

        operators[noId] = Operator({
            coldkey: coldkey,
            minerUid: uid,
            minerHotkey: minerHotkey,
            active: true
        });
        operatorIds.push(noId);
        emit OperatorRegistered(noId, coldkey, uid, minerHotkey);
    }

    function operatorCount() external view returns (uint256) {
        return operatorIds.length;
    }

    /// @notice Register an operator's server Ed25519 trail-signing key.
    ///         Owner-gated and append-only: a serverKeyId can never be
    ///         re-pointed, so historical trail leaves stay verifiable in
    ///         disputes (task spec; WHITEPAPER §11.3).
    /// @dev serverKeyId is GLOBALLY unique (across NOs) because a trail leaf
    ///      names only the key id.
    function setOperatorServerKey(uint256 noId, uint64 serverKeyId, bytes32 pubkey)
        external
        onlyOwner
    {
        require(operators[noId].minerHotkey != bytes32(0), "ST: no operator");
        require(pubkey != bytes32(0), "ST: pubkey 0");
        require(serverKeys[serverKeyId].pubkey == bytes32(0), "ST: key exists");
        serverKeys[serverKeyId] = ServerKey({noId: noId, pubkey: pubkey});
        emit OperatorServerKeySet(noId, serverKeyId, pubkey);
    }

    /// @notice The 32-byte digest signed (Ed25519, by `vpk`) for registerValidator.
    ///         digest = keccak256(abi.encodePacked(
    ///             keccak256("UR_ST_VPK_BIND_V1"),  // 32B domain
    ///             block.chainid,                    // 32B
    ///             address(this),                    // 20B proxy address
    ///             registrant,                       // 20B msg.sender
    ///             hotkey,                           // 32B
    ///             vpk                               // 32B
    ///         ))                                    // total 168B preimage
    function vpkBindDigest(address registrant, bytes32 hotkey, bytes32 vpk)
        public
        view
        returns (bytes32)
    {
        return keccak256(
            abi.encodePacked(VPK_BIND_DOMAIN, block.chainid, address(this), registrant, hotkey, vpk)
        );
    }

    /// @notice PERMISSIONLESS validator registration (D-10).
    ///         Requirements verified on-chain:
    ///         1. `ed25519Sig` (64B r||s) is a valid Ed25519 signature by `vpk`
    ///            over vpkBindDigest(msg.sender, hotkey, vpk) — proves vpk
    ///            possession and binds vpk <-> wallet <-> hotkey (0x402).
    ///         2. `hotkey` is a registered UID on `netuid` whose coldkey equals
    ///            mirror(msg.sender) = blake2b256("evm:"||msg.sender) — proves
    ///            msg.sender's mirror registered that UID (0x802 + blake2f).
    function registerValidator(bytes32 hotkey, bytes32 vpk, bytes calldata ed25519Sig)
        external
        nonReentrant
        returns (uint256 valId)
    {
        require(mirrorCheckEnabled, "ST: permissionless reg disabled");
        require(hotkey != bytes32(0) && vpk != bytes32(0), "ST: zero key");
        require(vpkToValidator[vpk] == 0, "ST: vpk used");
        require(hotkeyToValidator[hotkey] == 0, "ST: hotkey used");
        require(ed25519Sig.length == 64, "ST: sig length");

        bytes32 r = bytes32(ed25519Sig[0:32]);
        bytes32 s = bytes32(ed25519Sig[32:64]);
        require(
            _ed25519Verify(vpkBindDigest(msg.sender, hotkey, vpk), vpk, r, s), "ST: bad vpk sig"
        );

        uint16 uid = _findUid(hotkey);
        bytes32 coldkey = _mgColdkey(uid);
        require(coldkey == _mirror(msg.sender), "ST: coldkey != mirror(sender)");

        valId = _addValidator(hotkey, vpk, msg.sender, coldkey);
    }

    /// @notice Owner-gated fallback registration (D-10 records owner-gating as
    ///         the SP-1/SP-2 fallback: use when blake2f/0x402/0x802 are not
    ///         usable on the live runtime). Performs NO cryptographic checks;
    ///         the owner attests to the wallet<->hotkey<->vpk<->coldkey binding.
    function registerValidatorFor(
        address operator_,
        bytes32 hotkey,
        bytes32 vpk,
        bytes32 coldkey
    ) external onlyOwner returns (uint256 valId) {
        require(hotkey != bytes32(0) && vpk != bytes32(0), "ST: zero key");
        require(coldkey != bytes32(0), "ST: coldkey 0");
        require(vpkToValidator[vpk] == 0, "ST: vpk used");
        require(hotkeyToValidator[hotkey] == 0, "ST: hotkey used");
        valId = _addValidator(hotkey, vpk, operator_, coldkey);
    }

    function _addValidator(bytes32 hotkey, bytes32 vpk, address operator_, bytes32 coldkey)
        internal
        returns (uint256 valId)
    {
        valId = nextValId++;
        validators[valId] =
            Validator({hotkey: hotkey, vpk: vpk, operator: operator_, active: true});
        validatorColdkey[valId] = coldkey;
        vpkToValidator[vpk] = valId;
        hotkeyToValidator[hotkey] = valId;
        emit ValidatorRegistered(valId, hotkey, vpk, operator_, coldkey);
    }

    // ---------------------------------------------------------------------
    // Head tier — client_id <-> hotkey binding (WHITEPAPER §8.4 / §11.4, D-18)
    //
    // A top-level miner (its own UID, steered by validators on pure measured
    // quality, paid natively) publishes a DUAL-SIGNED association between the
    // client_id its trails are measured under and its subnet hotkey. It is
    // trust-minimized: no operator/server sits in the identity path. The proof
    // shape mirrors registerValidator (mirror + 0x402, D-10). Storage-only:
    // no custody, no reentrancy surface, permissionless (proven per-call, not
    // onlyOwner); a non-live-UID hotkey fails closed (the metagraph read
    // reverts). Validators read the two public mappings via eth_call.
    // ---------------------------------------------------------------------

    /// @notice The 32-byte digest signed (Ed25519, by `clientId`'s key) for
    ///         bindHead. Domain-separated exactly like vpkBindDigest:
    ///         keccak256(abi.encodePacked(
    ///             HEAD_BIND_DOMAIN,  // 32B domain
    ///             block.chainid,     // 32B
    ///             address(this),     // 20B proxy address
    ///             registrant,        // 20B msg.sender
    ///             hotkey,            // 32B
    ///             clientId           // 32B
    ///         )) — a 168-byte preimage.
    function headBindDigest(address registrant, bytes32 hotkey, bytes32 clientId)
        public
        view
        returns (bytes32)
    {
        return keccak256(
            abi.encodePacked(
                HEAD_BIND_DOMAIN, block.chainid, address(this), registrant, hotkey, clientId
            )
        );
    }

    /// @notice Bind (or re-point) a `client_id` to a top-level miner `hotkey`.
    ///         Permissionless but DUAL-PROVED, so a miner cannot claim a
    ///         client_id it does not operate and steal another provider's
    ///         measured quality (WHITEPAPER §8.4/§11.4):
    ///         1. client_id control — `clientIdSig` (64B r‖s) is a valid Ed25519
    ///            signature by `clientId` over headBindDigest(msg.sender,
    ///            hotkey, clientId) via 0x402. `clientId` doubles as the
    ///            client's Ed25519 public key (VALIDATOR.md §2 ckey/vpk).
    ///         2. hotkey control — `hotkey` is a LIVE UID on `netuid` whose
    ///            coldkey == mirror(msg.sender), exactly like registerValidator.
    ///
    /// @dev Bijection & rotation (the safe rule): the client_id is the DURABLE
    ///      identity; the hotkey CHURNS — head UIDs are reclaimed by
    ///      lowest-emission deregistration (§8.4), so a demoted/re-promoted
    ///      provider must be able to move its measured client_id onto a fresh
    ///      hotkey WITHOUT first unbinding a hotkey it may no longer control.
    ///      Therefore a bind whose client_id or hotkey is already tied to a
    ///      DIFFERENT counterpart RE-POINTS it, clearing the stale side. This is
    ///      safe precisely because the caller has just proven control of BOTH
    ///      keys — the exact authority needed to move either side — and no
    ///      unrelated binding is ever touched (an attacker without the client_id
    ///      private key cannot pass check (1), so no quality theft). Re-binding
    ///      the identical pair is idempotent. Every write keeps both maps paired,
    ///      so the mapping stays a clean bijection.
    function bindHead(bytes32 hotkey, bytes32 clientId, bytes calldata clientIdSig)
        external
        nonReentrant
    {
        require(hotkey != bytes32(0) && clientId != bytes32(0), "ST: zero key");
        require(clientIdSig.length == 64, "ST: sig length");

        // (1) client_id control — Ed25519 over the domain-separated, replay-proof
        //     digest (binds this wallet + hotkey + clientId together).
        bytes32 r = bytes32(clientIdSig[0:32]);
        bytes32 s = bytes32(clientIdSig[32:64]);
        require(
            _ed25519Verify(headBindDigest(msg.sender, hotkey, clientId), clientId, r, s),
            "ST: bad client sig"
        );

        // (2) hotkey control — a live UID whose coldkey mirrors the caller.
        //     _findUid reverts if the hotkey is not a live UID (fail-closed).
        uint16 uid = _findUid(hotkey);
        require(_mgColdkey(uid) == _mirror(msg.sender), "ST: coldkey != mirror(sender)");

        // Bijection: clear a stale counterpart on either side (rotation), then
        // write the pair. Both clears are authorized by the dual proof above.
        bytes32 prevClient = headHotkeyToClientId[hotkey];
        if (prevClient != bytes32(0) && prevClient != clientId) {
            delete headClientIdToHotkey[prevClient];
        }
        bytes32 prevHotkey = headClientIdToHotkey[clientId];
        if (prevHotkey != bytes32(0) && prevHotkey != hotkey) {
            delete headHotkeyToClientId[prevHotkey];
        }
        headHotkeyToClientId[hotkey] = clientId;
        headClientIdToHotkey[clientId] = hotkey;
        emit HeadBound(hotkey, clientId, uid, msg.sender);
    }

    /// @notice Release a head binding (demotion / exit). Same hotkey-control
    ///         proof as bindHead; clears both directions.
    function unbindHead(bytes32 hotkey) external nonReentrant {
        bytes32 clientId = headHotkeyToClientId[hotkey];
        require(clientId != bytes32(0), "ST: not bound");
        uint16 uid = _findUid(hotkey);
        require(_mgColdkey(uid) == _mirror(msg.sender), "ST: coldkey != mirror(sender)");
        delete headHotkeyToClientId[hotkey];
        delete headClientIdToHotkey[clientId];
        emit HeadUnbound(hotkey, clientId, uid, msg.sender);
    }

    // ---------------------------------------------------------------------
    // Deposits (α held as stake on treasuryHotkey; §6.3)
    // ---------------------------------------------------------------------

    /// @notice Credit a NO deposit for the CURRENT epoch. Push-then-credit
    ///         (see README): the NO first moves α onto
    ///         (coldkey = mirror(this), hotkey = treasuryHotkey) with
    ///         StakingV2.transferStake, then calls deposit(); the contract
    ///         checks getStake(treasury) covers accountedStake + alphaAmount
    ///         and attributes it. Slippage-free (stake never leaves α).
    ///         φ·amount is routed to the epoch's fee pool (§9.3).
    /// @dev Caller must be the NO's registered operator address (or owner) —
    ///      attribution of pushed stake must not be stealable.
    function deposit(uint256 noId, uint256 alphaAmount)
        external
        nonReentrant
        whenNotPausedST
        onlyOperatorOrOwner(noId)
    {
        _rollEpochs();
        _requireRolled();
        require(alphaAmount > 0, "ST: amount 0");
        require(operators[noId].active, "ST: operator inactive");

        uint256 treasury = _getStake(treasuryHotkey);
        require(treasury >= accountedStake + alphaAmount, "ST: stake not received");
        accountedStake += alphaAmount;

        uint256 e = epoch;
        uint256 fee = (alphaAmount * phiBps) / BPS;
        DT[e][noId] += alphaAmount;
        totalDT[e] += alphaAmount;
        depositNet[e][noId] += alphaAmount - fee;
        feePool[e] += fee;
        emit Deposited(e, noId, msg.sender, alphaAmount, fee);
    }

    /// @notice Add α to an epoch's fee pool (push-then-credit like deposit()).
    ///         v1 route for the ω·OwnerCut bounty co-funding (§9.3): the owner
    ///         cut accrues off-contract, so the owner pushes its ω slice here.
    ///         Permissionless — anyone may subsidize the bounty.
    // onlyOwner (review finding B): fundFeePool credits accountedStake from
    // whatever α is already on the treasury hotkey. Permissionless, it let
    // anyone absorb a NO's pushed-but-uncredited deposit into the fee pool
    // (theft, even at single-NO). It is the route for the owner's ω cut, so
    // owner-gating matches intent. Per-depositor accounting is the multi-NO fix.
    function fundFeePool(uint256 e, uint256 alphaAmount) external onlyOwner nonReentrant whenNotPausedST {
        _rollEpochs();
        require(alphaAmount > 0, "ST: amount 0");
        require(!finalized[e] && e >= nextFinalizeEpoch, "ST: finalized");

        uint256 treasury = _getStake(treasuryHotkey);
        require(treasury >= accountedStake + alphaAmount, "ST: stake not received");
        accountedStake += alphaAmount;

        feePool[e] += alphaAmount;
        emit FeePoolFunded(e, msg.sender, alphaAmount);
    }

    // ---------------------------------------------------------------------
    // Per-epoch operator commitment (close(e) .. +commitWindow)
    // ---------------------------------------------------------------------

    /// @notice Commit the NO's payout-share Merkle root for closed epoch `e`.
    ///         Leaves: keccak256(bytes.concat(keccak256(abi.encode(
    ///         bytes32 providerColdkey, uint256 shareBps)))) — OZ double-hash,
    ///         sorted-pair tree, Σ shareBps <= 10_000 (over-committing only
    ///         drains the NO's own pool early; §8.3).
    ///         Re-commits are allowed within the window (ops fix-ups); a pool
    ///         that never commits has its total carried to the next epoch (D-11).
    function commitOperator(uint256 e, uint256 noId, bytes32 payoutRoot, bytes calldata off)
        external
        onlyOperatorOrOwner(noId)
    {
        _rollEpochs();
        require(operators[noId].active, "ST: operator inactive");
        require(payoutRoot != bytes32(0), "ST: root 0");
        uint64 closeB = epochCloseBlock[e];
        require(e < epoch && closeB != 0, "ST: epoch open");
        require(block.number <= uint256(closeB) + uint256(epochWindows[e].commitWindowBlocks), "ST: commit window");
        require(!finalized[e], "ST: finalized");

        noCommit[e][noId] = NoCommit({payoutRoot: payoutRoot, off: off});
        emit OperatorCommitted(e, noId, payoutRoot, off);
    }

    // ---------------------------------------------------------------------
    // Per-epoch validator effort claims (close(e) .. +trailsWindow),
    // sampled verification, and disputes (until finalize) — §9.3 / §11.3
    // ---------------------------------------------------------------------

    /// @notice Submit the validator's effort claim for closed epoch `e`:
    ///         a Merkle root over TrailLeaf preimages (see trailLeafHash) plus
    ///         the claimed Σ coverage. Accepted optimistically; if sampleK > 0
    ///         it must then be backed by proveTrailSamples (seeded by the hash
    ///         of THIS block, so the tree cannot be built around the sample).
    ///         One submission per (e, valId); disputable until finalize.
    function submitTrails(uint256 e, uint256 valId, bytes32 trailsRoot_, uint256 claimedEffort)
        external
        whenNotPausedST
    {
        _rollEpochs();
        Validator storage v = validators[valId];
        require(v.active, "ST: validator inactive");
        require(msg.sender == v.operator, "ST: not validator");
        require(trailsRoot_ != bytes32(0), "ST: root 0");
        require(claimedEffort > 0, "ST: effort 0");
        // Bound so Σ claimedEffort (totalEffort) and feePool·effort can never
        // overflow uint256 — an unbounded claim would let one validator grief
        // every later _creditEffort (totalEffort overflow) and brick its own
        // claimValidator (feePool * effort overflow).
        require(claimedEffort <= type(uint128).max, "ST: effort too large");
        uint64 closeB = epochCloseBlock[e];
        require(e < epoch && closeB != 0, "ST: epoch open");
        require(block.number <= uint256(closeB) + uint256(epochWindows[e].trailsWindowBlocks), "ST: trails window");
        require(!finalized[e], "ST: finalized");
        require(trailsRoot[e][valId] == bytes32(0), "ST: submitted");

        trailsRoot[e][valId] = trailsRoot_;
        TrailSubmission storage sub = trailSubmission[e][valId];
        sub.claimedEffort = claimedEffort;
        sub.submitBlock = uint64(block.number);
        sub.seedBlock = uint64(block.number);

        if (sampleK == 0) {
            // k == 0 DISABLES effort (a debug/degenerate setting): with no
            // sample there is no unbiased estimator of the tree's coverage, so
            // we credit 0 rather than trust the free `claimedEffort` (F1). The
            // claim is still recorded (TrailsSubmitted) but earns no bounty —
            // effort[e][valId] stays 0, so claimValidator reverts "no credited
            // effort". Run with sampleK > 0 for the head/effort bounty to pay.
            sub.proven = true;
        }
        emit TrailsSubmitted(e, valId, trailsRoot_, claimedEffort);
    }

    /// @notice Sample seed for (e, valId): keccak256(blockhash(seedBlock), e, valId).
    ///         Available from seedBlock+1 to seedBlock+256.
    function trailSampleSeed(uint256 e, uint256 valId) public view returns (bytes32) {
        TrailSubmission storage sub = trailSubmission[e][valId];
        require(sub.seedBlock != 0, "ST: not submitted");
        require(block.number > uint256(sub.seedBlock), "ST: seed not ready");
        bytes32 bh = blockhash(uint256(sub.seedBlock));
        require(bh != bytes32(0), "ST: seed expired");
        return keccak256(abi.encodePacked(bh, e, valId));
    }

    /// @notice The k sampled leaf indices for a declared tree size.
    ///         index_i = uint256(keccak256(seed || i)) % leafCount.
    function sampleIndices(uint256 e, uint256 valId, uint256 leafCount)
        public
        view
        returns (uint256[] memory idx)
    {
        require(leafCount > 0, "ST: leafCount 0");
        bytes32 seed = trailSampleSeed(e, valId);
        uint256 k = sampleK;
        idx = new uint256[](k);
        for (uint256 i = 0; i < k; i++) {
            idx[i] = uint256(keccak256(abi.encodePacked(seed, i))) % leafCount;
        }
    }

    /// @notice Back the optimistic effort claim with the k sampled leaves.
    ///         For each sampled index the full leaf preimage plus a Merkle
    ///         proof into trailsRoot must be supplied; each leaf is checked:
    ///         proof ∈ trailsRoot, serverKeyId known, 0x402(finalDigest,
    ///         serverKey, serverSig), 0x402(finalDigest, vpk, vpkSig).
    ///         Success credits `claimedEffort` into effort/totalEffort
    ///         (still voidable by dispute until finalize). Permissionless —
    ///         the data decides.
    function proveTrailSamples(
        uint256 e,
        uint256 valId,
        uint256 leafCount,
        TrailLeaf[] calldata leaves,
        bytes32[][] calldata proofs
    ) external whenNotPausedST {
        _rollEpochs();
        TrailSubmission storage sub = trailSubmission[e][valId];
        require(trailsRoot[e][valId] != bytes32(0), "ST: not submitted");
        require(!sub.voided, "ST: voided");
        require(!sub.proven, "ST: proven");
        require(!finalized[e], "ST: finalized");
        uint64 closeB = epochCloseBlock[e];
        require(block.number <= uint256(closeB) + uint256(epochWindows[e].trailsWindowBlocks), "ST: trails window");

        uint256 k = sampleK;
        require(leaves.length == k && proofs.length == k, "ST: sample count");

        uint256[] memory idx = sampleIndices(e, valId, leafCount); // validates seed & leafCount
        bytes32 root = trailsRoot[e][valId];
        bytes32 vpk = validators[valId].vpk;
        uint256 coverageSum = 0;
        for (uint256 i = 0; i < k; i++) {
            require(leaves[i].index == idx[i], "ST: wrong sample index");
            require(leaves[i].index < leafCount, "ST: index >= leafCount");
            _requireValidLeaf(root, vpk, leaves[i], proofs[i]);
            coverageSum += leaves[i].coverage; // coverage is signed (A2) -> unforgeable
        }

        // F1: credit the sample estimator of the tree's Σ coverage —
        // estimate = mean sampled coverage · leafCount = (Σ coverage / k)·leafCount
        // — NOT the free `claimedEffort`. Coverage is server-signed (A2, cannot
        // be forged) and the credit is capped at the submit-time declaration, so
        // a validator's credit can never EXCEED what it publicly claimed and
        // declaring high does not inflate. The seed is post-submission, and
        // reseeds are capped (MAX_RESEEDS, HF-2) so the sample cannot be ground
        // by keep-the-best resampling. RESIDUAL (HF-2, bounded): within the few
        // permitted draws a validator can still bias the estimate slightly via
        // coverage variance, and `leafCount` is not verified against the tree
        // (declaring leafCount > real size and getting all k samples in-range is
        // a low-probability gamble once reseeds are capped). Full closure =
        // commit `leafCount` at submit (an ABI change); deferred — owner-run
        // launch validators make the residual non-exploitable at launch.
        // Multiply-before-divide keeps precision; any product overflow is the
        // validator's own prove reverting — it cannot grief other claims.
        uint256 estimate = (coverageSum * leafCount) / k;
        uint256 claimed = sub.claimedEffort;
        uint256 credit = estimate < claimed ? estimate : claimed;

        sub.leafCount = leafCount;
        sub.proven = true;
        _creditEffort(e, valId, credit);
        emit TrailSamplesProven(e, valId, leafCount);
    }

    /// @notice Refresh the sample seed if blockhash(seedBlock) fell out of the
    ///         256-block window before proveTrailSamples ran. Validator-only
    ///         (a third party could otherwise grief prepared proofs).
    function reseedTrailSamples(uint256 e, uint256 valId) external {
        TrailSubmission storage sub = trailSubmission[e][valId];
        require(msg.sender == validators[valId].operator, "ST: not validator");
        require(trailsRoot[e][valId] != bytes32(0), "ST: not submitted");
        require(!sub.voided && !sub.proven, "ST: settled");
        require(block.number > uint256(sub.seedBlock) + 256, "ST: seed live");
        require(reseedCount[e][valId] < MAX_RESEEDS, "ST: reseed limit"); // HF-2: cap the resample grind
        uint64 closeB = epochCloseBlock[e];
        require(block.number <= uint256(closeB) + uint256(epochWindows[e].trailsWindowBlocks), "ST: trails window");
        reseedCount[e][valId]++;
        sub.seedBlock = uint64(block.number);
        emit TrailSamplesReseeded(e, valId, sub.seedBlock);
    }

    /// @notice Dispute one committed effort leaf (WHITEPAPER §11.3). ANYONE may
    ///         call, any time from submission until finalize (a superset of the
    ///         +24h..+48h window — see README). The leaf must be IN the
    ///         committed tree; the dispute succeeds if the leaf is invalid:
    ///         unknown server key, bad FINAL server signature, bad vpk
    ///         signature, or an index outside the declared tree size.
    ///         One failing leaf voids the validator's whole epoch claim
    ///         (effort -> 0). No claim-path pause can block this.
    function disputeTrailLeaf(uint256 e, uint256 valId, TrailLeaf calldata leaf, bytes32[] calldata proof)
        external
    {
        _rollEpochs();
        TrailSubmission storage sub = _disputableSubmission(e, valId);

        bytes32 root = trailsRoot[e][valId];
        bytes32 lh = trailLeafHash(leaf);
        require(MerkleProof.verify(proof, root, lh), "ST: leaf not in tree");

        ServerKey storage sk = serverKeys[leaf.serverKeyId];
        // A2: sigs are checked over sha256(finalDigest ‖ coverage), so a leaf
        // with forged coverage fails the sig check here and is disputable.
        // leafCount is only declared via proveTrailSamples (which enforces
        // leafCount > 0); the sampleK == 0 credit path sets proven without a
        // declared tree size, so the index bound must not apply there —
        // otherwise EVERY valid leaf (index >= 0 == leafCount) would be
        // dispute-voidable.
        bytes32 msgDigest = effortDigest(leaf.finalDigest, leaf.coverage);
        bool bad = sk.pubkey == bytes32(0)
            || !_ed25519Verify(msgDigest, sk.pubkey, leaf.serverSigR, leaf.serverSigS)
            || !_ed25519Verify(msgDigest, validators[valId].vpk, leaf.vpkSigR, leaf.vpkSigS)
            || (sub.proven && sub.leafCount > 0 && leaf.index >= sub.leafCount);
        require(bad, "ST: leaf valid");

        _voidEffort(e, valId, sub);
        emit TrailLeafDisputed(e, valId, msg.sender, lh);
    }

    /// @notice Dispute a pair of DISTINCT committed leaves that double-count:
    ///         same index (index fraud vs the sampled verification) or same
    ///         pathId (one trail counted twice). Voids the epoch claim.
    function disputeTrailLeafPair(
        uint256 e,
        uint256 valId,
        TrailLeaf calldata a,
        bytes32[] calldata proofA,
        TrailLeaf calldata b,
        bytes32[] calldata proofB
    ) external {
        _rollEpochs();
        TrailSubmission storage sub = _disputableSubmission(e, valId);

        bytes32 root = trailsRoot[e][valId];
        bytes32 ha = trailLeafHash(a);
        bytes32 hb = trailLeafHash(b);
        require(MerkleProof.verify(proofA, root, ha), "ST: leaf A not in tree");
        require(MerkleProof.verify(proofB, root, hb), "ST: leaf B not in tree");
        require(ha != hb, "ST: same leaf");
        require(a.index == b.index || a.pathId == b.pathId, "ST: no double-count");

        _voidEffort(e, valId, sub);
        emit TrailLeafDisputed(e, valId, msg.sender, ha);
    }

    function _disputableSubmission(uint256 e, uint256 valId)
        internal
        view
        returns (TrailSubmission storage sub)
    {
        sub = trailSubmission[e][valId];
        require(trailsRoot[e][valId] != bytes32(0), "ST: not submitted");
        require(!sub.voided, "ST: voided");
        require(!finalized[e], "ST: finalized");
        uint64 closeB = epochCloseBlock[e];
        require(block.number < uint256(closeB) + uint256(epochWindows[e].finalizeOffsetBlocks), "ST: dispute window");
    }

    /// @dev The sampled-leaf check (§9.3): membership in the committed tree +
    ///      both Ed25519 signatures over the FINAL digest via 0x402.
    function _requireValidLeaf(
        bytes32 root,
        bytes32 vpk,
        TrailLeaf calldata leaf,
        bytes32[] calldata proof
    ) internal view {
        require(MerkleProof.verify(proof, root, trailLeafHash(leaf)), "ST: leaf not in tree");
        ServerKey storage sk = serverKeys[leaf.serverKeyId];
        require(sk.pubkey != bytes32(0), "ST: unknown server key");
        // A2: both sigs are verified over sha256(finalDigest ‖ coverage), so the
        // committed `coverage` is unforgeable (a validator cannot credit a
        // coverage the server never signed).
        bytes32 msgDigest = effortDigest(leaf.finalDigest, leaf.coverage);
        require(
            _ed25519Verify(msgDigest, sk.pubkey, leaf.serverSigR, leaf.serverSigS),
            "ST: bad server sig"
        );
        require(
            _ed25519Verify(msgDigest, vpk, leaf.vpkSigR, leaf.vpkSigS), "ST: bad vpk sig"
        );
    }

    function _creditEffort(uint256 e, uint256 valId, uint256 amount) internal {
        effort[e][valId] = amount;
        totalEffort[e] += amount;
    }

    function _voidEffort(uint256 e, uint256 valId, TrailSubmission storage sub) internal {
        sub.voided = true;
        uint256 credited = effort[e][valId];
        if (credited > 0) {
            totalEffort[e] -= credited;
            effort[e][valId] = 0;
        }
    }

    // ---------------------------------------------------------------------
    // Settlement (close(e) + finalizeOffset; permissionless; append-only)
    // ---------------------------------------------------------------------

    /// @notice Finalize closed epoch `e` (in order). Snapshots, per NO:
    ///         poolTotal = measured pool-hotkey stake delta (D-4)
    ///                   + (1-φ)·deposits + carried balance.
    ///         A pool with NO commit for `e` has that total carried to the
    ///         next epoch instead (D-11). totalEffort was accumulated by the
    ///         sample/dispute flow; if zero, the fee pool rolls to e+1.
    ///         After this, epoch e's claims are open and IMMUTABLE.
    function finalizeEpoch(uint256 e) external nonReentrant whenNotPausedST {
        _rollEpochs();
        require(e == nextFinalizeEpoch, "ST: finalize in order");
        uint64 closeB = epochCloseBlock[e];
        require(e < epoch && closeB != 0, "ST: epoch open");
        require(
            block.number >= uint256(closeB) + uint256(epochWindows[e].finalizeOffsetBlocks), "ST: finalize window"
        );
        require(!finalized[e], "ST: finalized");

        uint256 n = operatorIds.length;
        for (uint256 i = 0; i < n; i++) {
            uint256 noId = operatorIds[i];
            uint256 pt = poolEmission[e][noId] + depositNet[e][noId] + carry[noId];
            if (pt == 0) continue;
            if (noCommit[e][noId].payoutRoot == bytes32(0)) {
                carry[noId] = pt; // missed commit: roll the pool total forward
                emit PoolCarried(e, noId, pt);
            } else {
                poolTotal[e][noId] = pt;
                carry[noId] = 0;
                emit PoolFinalized(e, noId, pt);
            }
        }

        if (totalEffort[e] == 0 && feePool[e] > 0) {
            // no verified effort: the bounty rolls forward instead of stranding
            uint256 amt = feePool[e];
            feePool[e] = 0;
            feePool[e + 1] += amt;
            emit FeePoolRolled(e, e + 1, amt);
        }

        finalized[e] = true;
        nextFinalizeEpoch = e + 1;
        emit EpochFinalized(e, totalDT[e], feePool[e], totalEffort[e]);
    }

    // ---------------------------------------------------------------------
    // Claims (WHITEPAPER §8.3 / §11.2) — NO pause gate, NO admin path.
    // ---------------------------------------------------------------------

    /// @notice Miner-leaf hash: OZ double-hash of abi.encode(coldkey, shareBps).
    ///         NOTE: PLAN.md §2 double-hash OVERRIDES the single-hash snippet in
    ///         WHITEPAPER §11.2. sn/merkle (Go) must match this exactly.
    function minerLeafHash(bytes32 coldkey, uint256 shareBps) public pure returns (bytes32) {
        return keccak256(bytes.concat(keccak256(abi.encode(coldkey, shareBps))));
    }

    /// @notice Effort-leaf hash: OZ double-hash of the full 9-field TrailLeaf
    ///         preimage (see README "Effort leaf" for why signatures are inside
    ///         the committed leaf).
    function trailLeafHash(TrailLeaf memory leaf) public pure returns (bytes32) {
        return keccak256(
            bytes.concat(
                keccak256(
                    abi.encode(
                        leaf.index,
                        leaf.pathId,
                        leaf.coverage,
                        leaf.serverKeyId,
                        leaf.finalDigest,
                        leaf.serverSigR,
                        leaf.serverSigS,
                        leaf.vpkSigR,
                        leaf.vpkSigS
                    )
                )
            )
        );
    }

    /// @notice The 32-byte message the server + validator (vpk) Ed25519 sigs
    ///         attest for a trail leaf: `sha256(finalDigest ‖ coverage)` (0x02).
    ///         Binding `coverage` into the SIGNED message is the A2 fix — a
    ///         validator can no longer commit a `coverage` the server never
    ///         attested (forging per-leaf coverage now fails the sig check, so
    ///         it is disputable). The committed merkle leaf (`trailLeafHash`,
    ///         still the 9-field preimage) is UNCHANGED; only the message the
    ///         sigs verify over moves from `finalDigest` to this digest.
    ///         Matches `connect/verify_wire.go` and the cross-repo golden
    ///         vectors (`finalDigest` is 32B, `coverage` is a 32B big-endian
    ///         uint256 — 64 bytes total).
    function effortDigest(bytes32 finalDigest, uint256 coverage) public pure returns (bytes32) {
        return sha256(abi.encodePacked(finalDigest, coverage));
    }

    /// @notice Claim a provider's share of pool `noId` for finalized epoch `e`.
    ///         Permissionless (relayer-compatible, D-2): the α always goes to
    ///         `coldkey` as stake on treasuryHotkey via transferStake.
    ///         amount = shareBps · poolTotal / 10_000, cumulative-capped at
    ///         poolTotal (a NO whose shares exceed 1 only drains its own pool).
    function claimMiner(
        uint256 e,
        uint256 noId,
        bytes32 coldkey,
        uint256 shareBps,
        bytes32[] calldata proof
    ) external nonReentrant {
        require(finalized[e], "ST: not finalized");
        require(coldkey != bytes32(0), "ST: coldkey 0");
        require(shareBps > 0 && shareBps <= BPS, "ST: shareBps");
        bytes32 root = noCommit[e][noId].payoutRoot;
        require(root != bytes32(0), "ST: no commit");
        require(MerkleProof.verify(proof, root, minerLeafHash(coldkey, shareBps)), "ST: bad proof");

        bytes32 key = keccak256(abi.encode(noId, coldkey));
        require(!minerClaimedBy[e][key], "ST: claimed");
        minerClaimedBy[e][key] = true;

        uint256 amount = (shareBps * poolTotal[e][noId]) / BPS;
        claimedMiner[e][noId] += amount;
        require(claimedMiner[e][noId] <= poolTotal[e][noId], "ST: pool over-drained");

        _payout(coldkey, amount);
        emit MinerClaimed(e, noId, coldkey, shareBps, amount, msg.sender);
    }

    /// @notice Claim a validator's effort bounty for finalized epoch `e`:
    ///         feePool · effort / totalEffort — pure on-chain arithmetic, no
    ///         root (§9.3/§11.2). Permissionless; pays validatorColdkey[valId].
    function claimValidator(uint256 e, uint256 valId) external nonReentrant {
        require(finalized[e], "ST: not finalized");
        require(!valClaimed[e][valId], "ST: claimed");
        valClaimed[e][valId] = true;

        uint256 eff = effort[e][valId];
        require(eff > 0, "ST: no credited effort");
        uint256 amount = (feePool[e] * eff) / totalEffort[e];

        _payout(validatorColdkey[valId], amount);
        emit ValidatorClaimed(e, valId, amount, msg.sender);
    }

    function _payout(bytes32 coldkey, uint256 amount) internal {
        if (amount == 0) return;
        accountedStake -= amount;
        _transferStake(coldkey, treasuryHotkey, amount);
    }

    // ---------------------------------------------------------------------
    // Governance / policy surface (grouped for a later STSubnetPolicy
    // extraction per WHITEPAPER §6.4.3 — kept in-contract for v1).
    // Every setter here affects FUTURE epochs / future state only.
    // ---------------------------------------------------------------------

    function setFeeParams(uint256 phiBps_, uint256 omegaBps_) external onlyOwner {
        require(phiBps_ <= BPS && omegaBps_ <= BPS, "ST: bps > 10000");
        phiBps = phiBps_;
        omegaBps = omegaBps_;
        emit FeeParamsSet(phiBps_, omegaBps_);
    }

    function setEpochParams(
        uint64 tEpoch_,
        uint64 commitWindowBlocks_,
        uint64 trailsWindowBlocks_,
        uint64 finalizeOffsetBlocks_
    ) external onlyOwner {
        _checkEpochParams(tEpoch_, commitWindowBlocks_, trailsWindowBlocks_, finalizeOffsetBlocks_);
        tEpoch = tEpoch_;
        commitWindowBlocks = commitWindowBlocks_;
        trailsWindowBlocks = trailsWindowBlocks_;
        finalizeOffsetBlocks = finalizeOffsetBlocks_;
        emit EpochParamsSet(tEpoch_, commitWindowBlocks_, trailsWindowBlocks_, finalizeOffsetBlocks_);
    }

    function _checkEpochParams(uint64 tEpoch_, uint64 commitW, uint64 trailsW, uint64 finalizeOff)
        internal
        pure
    {
        require(tEpoch_ >= 1, "ST: tEpoch 0");
        // ordering only (equality allowed for operator flexibility). NOTE: for
        // a non-empty post-prove dispute buffer, operators should configure
        // trailsW < finalizeOff — at trailsW == finalizeOff a leaf proved at the
        // exact boundary block is undisputable (prove uses <=, dispute uses <).
        // Left as guidance, not enforced, so commit/trails windows may overlap
        // the finalize offset (review finding D, accepted LOW).
        require(commitW <= trailsW && trailsW <= finalizeOff, "ST: window order");
    }

    function setSampleK(uint16 sampleK_) external onlyOwner {
        sampleK = sampleK_;
        emit SampleKSet(sampleK_);
    }

    function setGuardian(address guardian_) external onlyOwner {
        guardian = guardian_;
        emit GuardianSet(guardian_);
    }

    /// @notice Guardian/owner pause (D-12): halts deposit, fundFeePool,
    ///         submitTrails/proveTrailSamples and finalizeEpoch (the opening of
    ///         NEW claims). It can NEVER touch finalized-epoch claims or
    ///         disputes — those functions carry no pause gate.
    function setPaused(bool paused_) external {
        require(msg.sender == guardian || msg.sender == owner(), "ST: not guardian");
        paused = paused_;
        emit PausedSet(paused_, msg.sender);
    }

    function setOperatorAddress(uint256 noId, address addr) external onlyOwner {
        require(operators[noId].minerHotkey != bytes32(0), "ST: no operator");
        operatorAddress[noId] = addr;
        emit OperatorAddressSet(noId, addr);
    }

    function setOperatorActive(uint256 noId, bool active) external onlyOwner {
        require(operators[noId].minerHotkey != bytes32(0), "ST: no operator");
        operators[noId].active = active;
        emit OperatorActiveSet(noId, active);
    }

    function setValidatorActive(uint256 valId, bool active) external onlyOwner {
        require(validators[valId].hotkey != bytes32(0), "ST: no validator");
        validators[valId].active = active;
        emit ValidatorActiveSet(valId, active);
    }

    /// @notice Disable/enable the permissionless registerValidator path
    ///         (SP-1/SP-2 fallback posture per D-10; owner-gated
    ///         registerValidatorFor remains available either way).
    function setMirrorCheckEnabled(bool enabled) external onlyOwner {
        mirrorCheckEnabled = enabled;
        emit MirrorCheckSet(enabled);
    }

    /// @notice SP-1 escape hatch: correct the contract's substrate coldkey if
    ///         the on-chain blake2f mirror computation mismatches the runtime.
    ///         Affects future stake measurements only (never finalized claims).
    function setSelfColdkey(bytes32 selfColdkey_) external onlyOwner {
        require(selfColdkey_ != bytes32(0), "ST: coldkey 0");
        selfColdkey = selfColdkey_;
        emit SelfColdkeySet(selfColdkey_);
    }

    // ---------------------------------------------------------------------
    // Precompile accessors — the ONLY places precompiles are touched.
    // Virtual + address-constant so SP-1 findings / tests can swap them
    // (tests vm.etch mock code at the canonical addresses).
    // ABIs UNVERIFIED against the live runtime: subtensor v3.2.7 (SP-1).
    // ---------------------------------------------------------------------

    function _staking() internal view virtual returns (IStaking) {
        return IStaking(ISTAKING_ADDRESS); // 0x805
    }

    function _neuron() internal view virtual returns (INeuron) {
        return INeuron(INeuron_ADDRESS); // 0x804
    }

    function _metagraph() internal view virtual returns (IMetagraph) {
        return IMetagraph(IMetagraph_ADDRESS); // 0x802
    }

    function _ed25519() internal view virtual returns (IEd25519Verify) {
        return IEd25519Verify(IED25519VERIFY_ADDRESS); // 0x402
    }

    /// @dev Contract-held α on `hotkey` (coldkey = selfColdkey), in rao.
    function _getStake(bytes32 hotkey) internal view virtual returns (uint256) {
        return _staking().getStake(hotkey, selfColdkey, uint256(netuid));
    }

    /// @dev Move contract-held stake between hotkeys; non-reverting (used in
    ///      the epoch roll so a precompile failure cannot brick the epoch
    ///      machine — the measurement baseline handles retry).
    function _tryMoveStake(bytes32 fromHotkey, bytes32 toHotkey, uint256 amount)
        internal
        virtual
        returns (bool ok)
    {
        (ok,) = address(_staking()).call(
            abi.encodeCall(
                IStaking.moveStake, (fromHotkey, toHotkey, uint256(netuid), uint256(netuid), amount)
            )
        );
    }

    /// @dev Pay out contract-held stake on `hotkey` to `destColdkey` (stays α
    ///      stake — slippage-free; recipients removeStake at their discretion).
    function _transferStake(bytes32 destColdkey, bytes32 hotkey, uint256 amount) internal virtual {
        _staking().transferStake(destColdkey, hotkey, uint256(netuid), uint256(netuid), amount);
    }

    function _burnedRegister(uint16 netuid_, bytes32 hotkey) internal virtual {
        _neuron().burnedRegister(netuid_, hotkey);
    }

    function _ed25519Verify(bytes32 message, bytes32 pubkey, bytes32 r, bytes32 s)
        internal
        view
        virtual
        returns (bool)
    {
        return _ed25519().verify(message, pubkey, r, s);
    }

    function _mgColdkey(uint16 uid) internal view virtual returns (bytes32) {
        return _metagraph().getColdkey(netuid, uid);
    }

    /// @dev Linear metagraph scan (no reverse lookup precompile for hotkeys at
    ///      v3.2.7). Bounded by the subnet UID cap (max_uids <= 256, PLAN §3.8).
    function _findUid(bytes32 hotkey) internal view virtual returns (uint16) {
        IMetagraph mg = _metagraph();
        uint16 n = mg.getUidCount(netuid);
        for (uint16 i = 0; i < n; i++) {
            if (mg.getHotkey(netuid, i) == hotkey) {
                return i;
            }
        }
        revert("ST: uid not found");
    }

    /// @dev H160 -> AccountId32 mirror via blake2f (0x09). Overridable /
    ///      bypassable (mirrorCheckEnabled=false + registerValidatorFor) if
    ///      blake2f is unavailable on the live runtime (SP-1).
    function _mirror(address account) internal view virtual returns (bytes32) {
        return Blake2b.mirror(account);
    }

    // ---------------------------------------------------------------------
    // UUPS
    // ---------------------------------------------------------------------

    function _authorizeUpgrade(address) internal override onlyOwner {}

    // --- head tier: client_id <-> hotkey binding (WHITEPAPER §8.4/§11.4, D-18) ---
    // Appended at the END of storage (not in the registries block above) so this
    // upgrade preserves every pre-existing slot: the two new mappings consume 2
    // of the reserved __gap slots (50 -> 48), the textbook UUPS append.
    // Bijective — one hotkey <-> one client_id; both public for validator
    // eth_call reads. See bindHead / unbindHead / headBindDigest below.
    mapping(bytes32 => bytes32) public headHotkeyToClientId; // hotkey  -> client_id
    mapping(bytes32 => bytes32) public headClientIdToHotkey; // client_id -> hotkey

    /// @dev Reserved storage for future upgrades / policy-module extraction.
    uint256[48] private __gap;
}
